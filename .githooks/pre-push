#!/usr/bin/env bash

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

base_ref=$("$repo_root/scripts/resolve_diff_base.sh" HEAD)

echo "Pre-push quality gate range: ${base_ref}..HEAD"
exec "$repo_root/scripts/fast_ci.sh" \
  --full-static \
  --fresh-coverage \
  --range "$base_ref" HEAD
